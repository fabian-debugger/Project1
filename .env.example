# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# WhatsApp group name (exact match)
WHATSAPP_GROUP_NAME=Boodschappen

# Cron schedule (default: Monday 14:00)
CRON_SCHEDULE=0 14 * * 1

# Tuinderij URL
TUINDERIJ_URL=https://www.tuinderijdelijsterbes.nl/

# Log level (debug, info, warn, error)
LOG_LEVEL=info
