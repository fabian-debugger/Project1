# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# WhatsApp group name (exact match)
WHATSAPP_GROUP_NAME=Boodschappen

# WhatsApp group ID (optional, avoids slow group lookup on low-memory VMs)
# Find this in the bot logs after sending a message in the group
WHATSAPP_GROUP_ID=

# Cron schedule (default: Monday 13:00 Amsterdam time)
CRON_SCHEDULE=0 13 * * 1

# Timezone for cron schedule
CRON_TIMEZONE=Europe/Amsterdam

# Tuinderij URL
TUINDERIJ_URL=https://www.tuinderijdelijsterbes.nl/

# Log level (debug, info, warn, error)
LOG_LEVEL=info
